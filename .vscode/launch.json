    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/thefindingofisaac.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "autoScraper",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/autoScraper.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "autoScraper --dry-run",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/autoScraper.js",
            "args": ["--dry-run"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "queryWiki collectible",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/queryWiki.js",
            "args": ["collectible"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "queryWiki trinket",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/queryWiki.js",
            "args": ["trinket"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "queryWiki pickup",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/queryWiki.js",
            "args": ["pickup"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "queryWiki merge",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/queryWiki.js",
            "args": ["merge"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "queryWiki merge",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/queryWiki.js",
            "args": ["merge"]
        }
    ]
}